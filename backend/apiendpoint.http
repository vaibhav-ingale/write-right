@ollamaBaseUrl = http://127.0.0.1:11434
@lmStudioBaseUrl = http://127.0.0.1:1234
@llmGatewayBaseUrl = http://127.0.0.1:8008
@backendBaseUrl = http://127.0.0.1:8000
@llmGatewayApiKey = llmgw-ZHXiMOKLVrD-a6roXT1pf-DE1XZFJDjp
@defaultModel = gemma3:4b

# ------------------------------------------------------------------
# OLLAMA DIRECT
# ------------------------------------------------------------------

###
# List models (Ollama)
GET {{ollamaBaseUrl}}/v1/models

###
# Chat completion (Ollama)
POST {{ollamaBaseUrl}}/v1/chat/completions
Content-Type: application/json

{
  "model": "{{defaultModel}}",
  "messages": [
    { "role": "user", "content": "Why is the sky blue?" }
  ]
}

# ------------------------------------------------------------------
# LM STUDIO DIRECT
# ------------------------------------------------------------------

###
# List models (LM Studio)
GET {{lmStudioBaseUrl}}/v1/models

###
# Chat completion (LM Studio)
# Replace model with one you have loaded in LM Studio.
POST {{lmStudioBaseUrl}}/v1/chat/completions
Content-Type: application/json

{
  "model": "mistralai/ministral-3-3b",
  "messages": [
    { "role": "user", "content": "Why is the sky blue?" }
  ]
}

# ------------------------------------------------------------------
# LLM GATEWAY DIRECT
# ------------------------------------------------------------------

###
# List models (LLM Gateway)
GET {{llmGatewayBaseUrl}}/v1/models
Authorization: Bearer {{llmGatewayApiKey}}

###
# Chat completion (LLM Gateway)
POST {{llmGatewayBaseUrl}}/v1/chat/completions
Content-Type: application/json
Authorization: Bearer {{llmGatewayApiKey}}

{
  "model": "{{defaultModel}}",
  "messages": [
    { "role": "user", "content": "Why is the sky blue?" }
  ]
}

# ------------------------------------------------------------------
# WRITERIGHT BACKEND (FASTAPI)
# ------------------------------------------------------------------

###
# Health check
GET {{backendBaseUrl}}/health

###
# List upstream models via backend
GET {{backendBaseUrl}}/v1/models

###
# Chat completion via backend (OpenAI-compatible message format)
POST {{backendBaseUrl}}/v1/chat/completions
Content-Type: application/json

{
  "model": "{{defaultModel}}",
  "messages": [
    { "role": "user", "content": "Why is the sky blue?" }
  ]
}

###
# Chat completion via backend (WriteRight structured format)
POST {{backendBaseUrl}}/v1/chat/completions
Content-Type: application/json

{
  "model": "{{defaultModel}}",
  "refinement": "grammar",
  "text": "I recieve the shipmant yesturday and item was broked",
  "maxWords": 40,
  "temperature": 0.5
}
