{
  "manifest_version": 3,
  "name": "AI Text Refiner",
  "version": "1.0.0",
  "description": "Refine text in any textbox with a local LLM backend.",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "AI Text Refiner",
    "default_popup": "popup.html"
  }
}
